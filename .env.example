# Dataset discovery platform - supported local setup
# Copy this file to .env if you want to override defaults.

# Local demo catalog path used by the supported root demo/run path.
DUCKDB_PATH=data/demo_discovery.duckdb

# API host/port for local development.
API_HOST=127.0.0.1
API_PORT=8000

# Optional Hugging Face token for unsupported networked workflows.
# The supported first-pass demo and smoke tests do not require it.
HF_TOKEN=

# Keep prefetch on by default; supported first-pass demo data does not depend on it.
PREFETCH_ENABLED=true
